    "\n",
    "    # Step 3: Rollout\n",
    "    rollout_result = tree.make_rollout(node)\n",
    "\n",
    "    # Step 4: Backpropagate\n",
    "    tree.backpropagate(node, rollout_result)\n",
    "\n",
    "    counter += 1\n",
    "\n",
