    "    \"ucb_constant\": 1 / np.sqrt(2),\n",
    "    \"beam_width\": np.inf,\n",
    "    \"n_iterations\": 100,\n",
    "    \"rng\":rng\n",
    "}\n",
    "\n",
    "# Show initial state\n",
    "root = game.initial_state\n",
    "game.render(state)"
