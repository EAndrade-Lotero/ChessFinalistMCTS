    "    root=state,\n",
    "    game=game,\n",
    "    rollout_policy=random_policy,\n",
    "    **params\n",
    ")\n",
    "\n",
    "counter = 0\n",
    "while counter < tree.n_iterations:\n",
    "\n",
    "    # Step 1: Node selection\n",
    "    node = tree.select_ucb()\n",
    "    if node is None:\n",
    "        raise Exception(f\"Ooops, no ucb selection from node {node}\")\n",
    "    if node.is_fully_expanded():\n",
